{
  "name": "token-viewer",
  "displayName": "Token Viewer",
  "description": "在 VSCode 状态栏实时显示小米 MiMo 平台的剩余 Token 数量",
  "version": "1.1.0",
  "publisher": "bynlk",
  "repository": {
    "type": "git",
    "url": "https://github.com/Bynlk/Token-Viewer.git"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "tokenViewer.refresh",
        "title": "Token Viewer: 刷新 Token 数量"
      },
      {
        "command": "tokenViewer.configure",
        "title": "Token Viewer: 配置 Cookie"
      }
    ],
    "configuration": {
      "title": "Token Viewer",
      "properties": {
        "tokenViewer.headers": {
          "type": "object",
          "default": {},
          "description": "请求头（JSON 对象），只需填写 Cookie"
        },
        "tokenViewer.refreshInterval": {
          "type": "number",
          "default": 300,
          "minimum": 10,
          "description": "自动刷新间隔（秒），最小值为 10 秒"
        },
        "tokenViewer.alertThreshold": {
          "type": "number",
          "default": 10000000,
          "minimum": 0,
          "description": "告警阈值，当剩余 Token 小于等于此值时显示警告"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^18.19.0",
    "@types/vscode": "^1.74.0",
    "typescript": "^5.3.0"
  }
}
